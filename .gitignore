# =============================================================================
# BKPI Flash Sale Project — .gitignore
# Stack: Node.js · TypeScript · Fastify · Prisma · React · Vite · Docker
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# -----------------------------------------------------------------------------
# Build Output
# -----------------------------------------------------------------------------
dist/
build/
out/
.output/

# Vite build cache
frontend/.vite/

# -----------------------------------------------------------------------------
# Environment Variables (SENSITIVE — never commit these)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example

# -----------------------------------------------------------------------------
# Prisma
# -----------------------------------------------------------------------------
# Generated Prisma client (regenerated via `prisma generate`)
backend/node_modules/.prisma/
backend/src/generated/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# OS & Editor Files
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# VS Code (keep settings.json if team-shared, ignore user-specific)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# JetBrains IDEs
.idea/
*.iml

# Vim / Emacs
*.swp
*.swo
*~
\#*\#

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# Docker (local volumes / secrets)
# -----------------------------------------------------------------------------
# Ignore local Docker override files that may contain secrets
docker-compose.override.yml
docker-compose.local.yml

# Docker volume data (if mounted locally)
postgres_data/
redis_data/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.pem
*.key
*.cert
.cache/
.temp/
.tmp/
