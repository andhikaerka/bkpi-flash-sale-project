generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String     @id @default(uuid())
  name          String
  initial_stock Int
  current_stock Int
  start_time    DateTime
  end_time      DateTime
  purchases     Purchase[]

  @@map("products")
}

model Purchase {
  id         String   @id @default(uuid())
  user_id    String
  product_id String
  created_at DateTime @default(now())

  product    Product  @relation(fields: [product_id], references: [id])

  @@unique([user_id, product_id])
  @@map("purchases")
}